# ============================================================
# MAGANG-CERDAS PWA - Environment Variables (TEMPLATE)
# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to git
# ============================================================

# ---- SUPABASE ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD

# ---- GEOFENCING ----
# Default: BPJS Ketenagakerjaan Cabang Cirebon (-6.7386200, 108.5372200)
NEXT_PUBLIC_GEOLOC_OFFICE_LAT=-6.7386200
NEXT_PUBLIC_GEOLOC_OFFICE_LNG=108.5372200
NEXT_PUBLIC_GEOFENCE_RADIUS=150

# ---- LLM PROVIDERS (Multi-provider support) ----
# Active provider: groq | openai | anthropic | gemini | deepseek | qwen | mistral | zhipu
LLM_PROVIDER=groq

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash

# DeepSeek (China - https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_MODEL=deepseek-chat

# Alibaba Qwen / DashScope (China - https://dashscope.console.aliyun.com/)
QWEN_API_KEY=YOUR_QWEN_API_KEY
QWEN_MODEL=qwen-plus

# Mistral (https://console.mistral.ai/api-keys)
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
MISTRAL_MODEL=mistral-small-latest

# Zhipu GLM (China - https://open.bigmodel.cn/usercenter/apikeys)
ZHIPU_API_KEY=YOUR_ZHIPU_API_KEY
ZHIPU_MODEL=glm-4-flash

# ---- AUTH ----
JWT_SECRET=YOUR_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS
ADMIN_DEFAULT_EMAIL=admin@magang-cerdas.local
ADMIN_DEFAULT_PASSWORD=admin123456

# ---- APP INFO ----
NEXT_PUBLIC_APP_NAME=MAGANG-CERDAS
NEXT_PUBLIC_OFFICE_NAME=BPJS Ketenagakerjaan Cabang Cirebon
